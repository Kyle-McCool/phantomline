# Phantomline local environment template.
#
# 1. Copy this file to .env in the same directory.
# 2. Fill in the real values (Kyle has the production secrets — ask
#    him via Signal / 1Password share, NOT Slack or email).
# 3. .env is in .gitignore — never commit real secrets.

# -----------------------------------------------------------------------------
# REQUIRED — license signing
# -----------------------------------------------------------------------------
# HMAC-SHA256 secret used to sign and verify offline license keys
# (format: GHL1.<base64-payload>.<base64-signature>). MUST match whatever
# backend issues keys after Stripe checkout (the Supabase Edge Function in
# supabase/functions/issue-license/). Generate a fresh one for local dev:
#   openssl rand -hex 32
# But for shared dev against staging/prod license keys, ask Kyle for the
# real value.
GHOSTLINE_LICENSE_SECRET=replace_with_64_char_hex_from_kyle

# -----------------------------------------------------------------------------
# OPTIONAL — YouTube research routes
# -----------------------------------------------------------------------------
# YouTube Data API v3 key. Each Google Cloud project gets 10,000 units/day,
# so add YOUTUBE_API_KEY_3, _4, _5 to raise the daily ceiling. Without this,
# /api/research/* routes return 503.
YOUTUBE_API_KEY_2=

# -----------------------------------------------------------------------------
# OPTIONAL — in-app YouTube publishing (OAuth)
# -----------------------------------------------------------------------------
# OAuth client credentials for the "publish directly to YouTube" flow.
# Without these, the publish flow falls back to "render the MP4, user
# uploads manually." Get them from Google Cloud Console → APIs &
# Services → Credentials → OAuth 2.0 Client IDs.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL — telemetry forwarding
# -----------------------------------------------------------------------------
# If set, error events POST to this URL (typically a Supabase function).
# Local JSONL telemetry in output/telemetry/ works regardless.
# GHOSTLINE_TELEMETRY_URL=https://<your-supabase-ref>.supabase.co/functions/v1/telemetry

# -----------------------------------------------------------------------------
# Cloud sync — Supabase (account portal + project library across devices)
# -----------------------------------------------------------------------------
# These two values are PUBLIC by design — they ship in the deployed
# JavaScript on phantomline.xyz already. Baking them into the local
# install means your projects, license, and library follow you across
# devices automatically: render on your desktop, view from your phone,
# pick up where you left off on a different machine.
#
# Both values pre-filled to point at production Supabase. Override only
# if you're testing against your own Supabase project.
SUPABASE_URL=https://vdzydhrgazqeyaalguuy.supabase.co
# Get the publishable anon key from Supabase dashboard:
#   Project Settings → API → "Project API keys" → "anon" → Copy
# Or — easier — just open https://phantomline.xyz/account in a browser,
# View Source, and copy the value of <meta name="supabase-anon-key">.
# It's the same key Kyle ships in the deployed JS, so no secret leak.
SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Activate cloud project sync. With this on, /api/projects calls go
# through Supabase (gated by your signed-in session — RLS enforces
# you only see your own rows). Off = projects stay local-only on disk.
PHANTOMLINE_USE_SUPABASE_PROJECTS=true

# -----------------------------------------------------------------------------
# OPTIONAL — server-side admin (DO NOT SET LOCALLY)
# -----------------------------------------------------------------------------
# The service_role key bypasses RLS. Production (Render) sets it for the
# license-by-email lookup. Local installs MUST NOT set this — your
# user JWT does the authorization, and a stray service_role key on
# someone's laptop is a foot-gun. Left commented for documentation.
# SUPABASE_SERVICE_ROLE_KEY=             # Render only
# STRIPE_SECRET_KEY=                     # Render only — Customer Portal sessions

# -----------------------------------------------------------------------------
# OPTIONAL — license secret rotation
# -----------------------------------------------------------------------------
# Comma-separated list of OLD license secrets to keep accepting during a
# rotation window. Existing customer keys signed with these still validate
# until they're reissued.
# GHOSTLINE_LICENSE_SECRETS_LEGACY=old_secret_1,old_secret_2
